{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "A task assigned to an employee",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "assignedTo": { "type": "string" },
        "assignedBy": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "assignedTo", "assignedBy", "createdAt", "updatedAt"]
    },
    "Log": {
      "title": "Activity Log",
      "description": "System activity logs for audit purposes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Main user collection"
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Main tasks collection"
    },
    "logs/{logId}": {
      "schema": "Log",
      "description": "Activity tracking logs"
    }
  }
}
